PROJECT_NAME           = "constfilt"
PROJECT_BRIEF          = "Compile-time IIR digital filter design for C++17"
PROJECT_NUMBER         =

OUTPUT_DIRECTORY       = docs/api

INPUT                  = include/constfilt/constfilt.hpp \
                         include/constfilt/constfilt_options.hpp \
                         include/constfilt/filter.hpp \
                         include/constfilt/analog_filter.hpp \
                         include/constfilt/discretize.hpp \
                         include/constfilt/butterworth.hpp \
                         include/constfilt/elliptic.hpp \
                         include/constfilt/stability.hpp

RECURSIVE              = NO

EXCLUDE_PATTERNS       = */tests/* */googletest/* */Testing/* */build/* */vendor/*

FILE_PATTERNS          = *.hpp

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_UNDOC_MEMBERS     = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
HTML_OUTPUT            = .

USE_MATHJAX            = YES
MATHJAX_VERSION        = MathJax_3

HAVE_DOT               = YES
DOT_GRAPH_MAX_NODES    = 50
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
TEMPLATE_RELATIONS     = YES

BUILTIN_STL_SUPPORT    = NO
SORT_MEMBER_DOCS       = NO
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO

SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
SHOW_INCLUDE_FILES     = YES

TYPEDEF_HIDES_STRUCT   = NO
